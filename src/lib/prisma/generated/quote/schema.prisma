generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/prisma/generated/quote"
}

datasource db {
  provider = "mongodb"
  url      = env("QUOTE_PLUGIN_URL")
}

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String    @unique
  squarespaceUserId String?   @map("squarespace_user_id")
  hasUsedTrial      Boolean?
  isEmailVerified   Boolean?
  createdAt         DateTime? @default(now())
  updatedAt         DateTime? @updatedAt
  licenses          License[]

  @@map("users")
}

model License {
  id                        String    @id @default(auto()) @map("_id") @db.ObjectId
  name                      String?
  websiteId                 String?
  websiteUrl                String?
  businessEmail             String?
  userId                    String    @map("user") @db.ObjectId
  user                      User      @relation(fields: [userId], references: [id])
  settings                  Json?
  stripeCustomerId          String?
  stripeSubscriptionId      String?
  subscriptionStatus        String?
  stripePriceId             String?
  trialEndsAt               DateTime?
  cancelAtPeriodEnd         Boolean?
  canceledAt                DateTime?
  googleIntegration         Json?
  squarespaceWebsiteId      String?
  squarespaceTokenExpiresAt DateTime?
  quoteButtonPosition       String?
  quoteLabel                String?
  buttonTextColor           String?
  isQuantityVisible         Boolean?
  customFields              Json?
  createdAt                 DateTime? @default(now())
  updatedAt                 DateTime? @updatedAt

  @@map("licenses")
}
